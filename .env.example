FMKOREA_BOARD_URL=https://m.fmkorea.com/hotdeal
FMKOREA_BOARD_URLS=https://www.fmkorea.com/hotdeal
CRAWL_MODE=playwright
ALERT_KEYWORDS=삼다수,요기요
REQUEST_INTERVAL_MS=300000
REQUEST_TIMEOUT_MS=20000
MAX_ITEMS_PER_POLL=30
MAX_PAGES_PER_POLL=3
STATE_FILE_PATH=./data/seen.json
USE_FILE_STATE=false
USE_REDIS_STATE=false
REDIS_URL=redis://fmkorea-hotdeal-redis:6379
REDIS_KEY_PREFIX=hotdeal:seen:
REDIS_TTL_SECONDS=0
SHOW_RECENT_MATCHES=true
LOOKBACK_HOURS=168
STARTUP_LOOKBACK_HOURS=24
RUN_ONCE=false
DRY_RUN=false
USER_AGENT=Mozilla/5.0 (compatible; FMKoreaHotdealMonitor/1.0; +https://example.com)
PLAYWRIGHT_WS_ENDPOINT=
PLAYWRIGHT_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_NAV_TIMEOUT_MS=20000
PLAYWRIGHT_WAIT_AFTER_LOAD_MS=900

# Slack
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Telegram
# TELEGRAM_BOT_TOKEN=000000:xxxxxxxx
# TELEGRAM_CHAT_ID=123456789

# Optional HTML selectors for tighter parsing
# POST_SELECTOR=.post_list .item
# LINK_SELECTOR=a.title
# TITLE_SELECTOR=.title
